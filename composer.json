{
    "name": "shubo/module-shipping-core",
    "description": "Carrier-agnostic shipping orchestration framework for Magento 2 marketplaces and multi-vendor stores",
    "type": "magento2-module",
    "version": "0.10.0",
    "license": "Apache-2.0",
    "keywords": ["magento2", "shipping", "carrier", "marketplace", "logistics", "cod", "georgia"],
    "authors": [
        {
            "name": "Shubo",
            "email": "dev@shubo.ge",
            "homepage": "https://github.com/nshubitidze/module-shipping-core",
            "role": "Maintainer"
        }
    ],
    "homepage": "https://github.com/nshubitidze/module-shipping-core",
    "support": {
        "issues": "https://github.com/nshubitidze/module-shipping-core/issues",
        "source": "https://github.com/nshubitidze/module-shipping-core"
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "magento/framework": ">=103.0",
        "magento/module-shipping": ">=100.4",
        "magento/module-sales": ">=103.0",
        "magento/module-quote": ">=101.2",
        "magento/module-store": ">=101.1",
        "phpoffice/phpspreadsheet": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12",
        "bitexpert/phpstan-magento": "^0.32",
        "squizlabs/php_codesniffer": "^3.10",
        "magento/magento-coding-standard": "^37.0",
        "magento/framework": "^103.0.7"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://mirror.mage-os.org/"
        }
    ],
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Shubo\\ShippingCore\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Shubo\\ShippingCore\\Test\\": "Test/"
        }
    },
    "config": {
        "platform": {
            "php": "8.4.0"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "magento/composer-dependency-version-audit-plugin": true,
            "magento/composer-root-update-plugin": true,
            "magento/inventory-composer-installer": true,
            "laminas/laminas-dependency-plugin": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "scripts": {
        "phpunit": "phpunit",
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs"
    }
}
