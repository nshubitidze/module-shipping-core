includes:
    - vendor/bitexpert/phpstan-magento/extension.neon
parameters:
    level: 8
    paths:
        - Api
        - Controller
        - Exception
        - Model
        - Observer
        - Ui
    excludePaths:
        - Test/*
        - vendor/*
    treatPhpDocTypesAsCertain: false
    # bitexpert/phpstan-magento resolves most Magento classes via its
    # autoloader, but a handful of framework classes aren't available
    # without a full Magento install — silence those to keep level 8.
    ignoreErrors: []
