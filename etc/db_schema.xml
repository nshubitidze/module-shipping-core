<?xml version="1.0"?>
<!--
    Copyright © Shubo. All rights reserved.
    See LICENSE file for license details.

    Shubo_ShippingCore declarative schema.

    Money columns are stored as integer tetri (bigint) per architect's decision
    (memory: reference_shipping_core_module, decision #1). Conversion to
    decimal(20,4) happens at the Shubo_Payout boundary via an observer.
-->
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- ================================================================
         6.1 shubo_shipping_shipment
         One row per marketplace shipment. Primary source of truth.
         ================================================================ -->
    <table name="shubo_shipping_shipment" resource="default" engine="innodb"
           comment="Shipment — carrier-agnostic marketplace shipment record">
        <column xsi:type="int" name="shipment_id" unsigned="true" nullable="false"
                identity="true" comment="Internal Shipment ID"/>
        <column xsi:type="int" name="magento_shipment_id" unsigned="true" nullable="true"
                comment="FK to sales_shipment.entity_id; nullable for dispatch-ahead flow"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="false"
                comment="FK to sales_order.entity_id"/>
        <column xsi:type="int" name="merchant_id" unsigned="true" nullable="false"
                comment="FK to shubo_merchant.merchant_id"/>
        <column xsi:type="varchar" name="carrier_code" nullable="false" length="40"
                comment="Carrier code used for CarrierRegistry lookup"/>
        <column xsi:type="varchar" name="carrier_tracking_id" nullable="true" length="128"
                comment="Carrier-issued tracking identifier (nullable until createShipment returns)"/>
        <column xsi:type="varchar" name="client_tracking_code" nullable="false" length="36"
                comment="UUIDv7 generated by us — primary idempotency key for createShipment"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending"
                comment="Normalized status (see Section 10.1)"/>
        <!-- pickup_address_id FK to shubo_merchant_pickup_address added in Phase 2;
             kept nullable in Phase 1 because the referenced table does not exist yet. -->
        <column xsi:type="int" name="pickup_address_id" unsigned="true" nullable="true"
                comment="FK to shubo_merchant_pickup_address (Phase 2); nullable in Phase 1"/>
        <column xsi:type="text" name="delivery_address_json" nullable="false"
                comment="Serialized normalized ContactAddress DTO"/>
        <column xsi:type="int" name="parcel_weight_grams" unsigned="true" nullable="false"
                default="0" comment="Parcel weight in integer grams; 0 = unknown"/>
        <column xsi:type="bigint" name="parcel_value_cents" unsigned="true" nullable="false"
                default="0" comment="Declared parcel value in tetri"/>
        <column xsi:type="smallint" name="cod_enabled" nullable="false" default="0"
                comment="Cash-on-delivery enabled flag (0/1)"/>
        <column xsi:type="bigint" name="cod_amount_cents" unsigned="true" nullable="false"
                default="0" comment="COD amount in tetri; non-zero iff cod_enabled=1"/>
        <column xsi:type="timestamp" name="cod_collected_at" nullable="true"
                comment="When carrier reports courier collected cash"/>
        <column xsi:type="timestamp" name="cod_reconciled_at" nullable="true"
                comment="When invoice reconciliation matched the COD line"/>
        <column xsi:type="varchar" name="label_url" nullable="true" length="1024"
                comment="Remote URL to carrier label PDF"/>
        <column xsi:type="varchar" name="label_pdf_stored_at" nullable="true" length="255"
                comment="Path under pub/media/shubo_shipping/labels/ once downloaded"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Creation timestamp"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP"
                on_update="true" comment="Last update timestamp"/>
        <column xsi:type="timestamp" name="last_polled_at" nullable="true"
                comment="When TrackingPoller last fetched status"/>
        <column xsi:type="timestamp" name="next_poll_at" nullable="true"
                comment="Priority queue field for poller; NULL for terminal rows"/>
        <column xsi:type="varchar" name="poll_strategy" nullable="false" length="20" default="adaptive"
                comment="Poll strategy: adaptive | frequent | disabled"/>
        <column xsi:type="varchar" name="webhook_secret" nullable="true" length="255"
                comment="Per-shipment webhook secret (encrypted)"/>
        <column xsi:type="timestamp" name="failed_at" nullable="true"
                comment="When dispatch last failed (pre-retry-exhaustion)"/>
        <column xsi:type="text" name="failure_reason" nullable="true"
                comment="Last error message; cleared on success"/>
        <column xsi:type="text" name="metadata_json" nullable="true"
                comment="Free-form carrier extras (JSON)"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="shipment_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="SHUBO_SHIPPING_SHIPMENT_CARRIER_CODE_CLIENT_TRACKING_CODE">
            <column name="carrier_code"/>
            <column name="client_tracking_code"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="SHUBO_SHIPPING_SHIPMENT_ORDER_ID_SALES_ORDER_ENTITY_ID"
                    table="shubo_shipping_shipment" column="order_id"
                    referenceTable="sales_order" referenceColumn="entity_id"
                    onDelete="NO ACTION"/>
        <constraint xsi:type="foreign" referenceId="SHUBO_SHIPPING_SHIPMENT_MERCHANT_ID_SHUBO_MERCHANT_MERCHANT_ID"
                    table="shubo_shipping_shipment" column="merchant_id"
                    referenceTable="shubo_merchant" referenceColumn="merchant_id"
                    onDelete="NO ACTION"/>
        <constraint xsi:type="foreign" referenceId="SHUBO_SHIPPING_SHIPMENT_MAGENTO_SHIPMENT_ID_SALES_SHIPMENT_ENTITY_ID"
                    table="shubo_shipping_shipment" column="magento_shipment_id"
                    referenceTable="sales_shipment" referenceColumn="entity_id"
                    onDelete="SET NULL"/>

        <index referenceId="SHUBO_SHIPPING_SHIPMENT_CARRIER_CODE_CARRIER_TRACKING_ID" indexType="btree">
            <column name="carrier_code"/>
            <column name="carrier_tracking_id"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_SHIPMENT_MAGENTO_SHIPMENT_ID" indexType="btree">
            <column name="magento_shipment_id"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_SHIPMENT_ORDER_ID" indexType="btree">
            <column name="order_id"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_SHIPMENT_MERCHANT_ID" indexType="btree">
            <column name="merchant_id"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_SHIPMENT_STATUS_NEXT_POLL_AT" indexType="btree">
            <column name="status"/>
            <column name="next_poll_at"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_SHIPMENT_MERCHANT_ID_CREATED_AT" indexType="btree">
            <column name="merchant_id"/>
            <column name="created_at"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_SHIPMENT_CARRIER_CODE_STATUS" indexType="btree">
            <column name="carrier_code"/>
            <column name="status"/>
        </index>
    </table>

    <!-- ================================================================
         6.2 shubo_shipping_shipment_event
         Append-only state-transition log.
         ================================================================ -->
    <table name="shubo_shipping_shipment_event" resource="default" engine="innodb"
           comment="Shipment Event — append-only log of state transitions, polls, webhooks">
        <column xsi:type="bigint" name="event_id" unsigned="true" nullable="false"
                identity="true" comment="Event ID"/>
        <column xsi:type="int" name="shipment_id" unsigned="true" nullable="false"
                comment="FK to shubo_shipping_shipment.shipment_id"/>
        <!-- Denormalized from shipment.carrier_code so the (carrier_code, external_event_id)
             dedup index can be a regular composite index without joining. -->
        <column xsi:type="varchar" name="carrier_code" nullable="false" length="40"
                comment="Denormalized carrier code for webhook-replay-dedup index"/>
        <column xsi:type="varchar" name="event_type" nullable="false" length="32"
                comment="Event type enum (see ShipmentEventInterface)"/>
        <column xsi:type="varchar" name="carrier_status_raw" nullable="true" length="64"
                comment="Exact status string sent by carrier"/>
        <column xsi:type="varchar" name="normalized_status" nullable="true" length="32"
                comment="Normalized status; NULL for events that don't change status"/>
        <column xsi:type="timestamp" name="occurred_at" nullable="true"
                comment="When the carrier says the event happened"/>
        <column xsi:type="timestamp" name="received_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="When we wrote the row"/>
        <column xsi:type="varchar" name="source" nullable="false" length="10"
                comment="Source enum: webhook | poll | manual | system"/>
        <column xsi:type="varchar" name="external_event_id" nullable="true" length="128"
                comment="Carrier-provided event UUID; used as replay-dedup key"/>
        <column xsi:type="mediumtext" name="raw_payload_json" nullable="true"
                comment="Full webhook body or poll response (audit)"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="event_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="SHUBO_SHIPPING_SHIPMENT_EVENT_CARRIER_CODE_EXTERNAL_EVENT_ID">
            <column name="carrier_code"/>
            <column name="external_event_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="SHUBO_SHIPPING_SHIPMENT_EVENT_SHIPMENT_ID"
                    table="shubo_shipping_shipment_event" column="shipment_id"
                    referenceTable="shubo_shipping_shipment" referenceColumn="shipment_id"
                    onDelete="CASCADE"/>

        <index referenceId="SHUBO_SHIPPING_SHIPMENT_EVENT_SHIPMENT_ID_RECEIVED_AT" indexType="btree">
            <column name="shipment_id"/>
            <column name="received_at"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_SHIPMENT_EVENT_RECEIVED_AT" indexType="btree">
            <column name="received_at"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_SHIPMENT_EVENT_EVENT_TYPE" indexType="btree">
            <column name="event_type"/>
        </index>
    </table>

    <!-- ================================================================
         6.3 shubo_shipping_carrier_config
         Per-carrier runtime settings.
         ================================================================ -->
    <table name="shubo_shipping_carrier_config" resource="default" engine="innodb"
           comment="Carrier Config — per-carrier runtime settings and encrypted credentials">
        <column xsi:type="varchar" name="carrier_code" nullable="false" length="40"
                comment="Carrier code (PK)"/>
        <column xsi:type="smallint" name="is_enabled" nullable="false" default="0"
                comment="Global kill switch (0/1)"/>
        <column xsi:type="smallint" name="is_sandbox" nullable="false" default="0"
                comment="Per-carrier sandbox toggle (0/1)"/>
        <column xsi:type="int" name="priority" unsigned="true" nullable="false" default="100"
                comment="Selection priority; lower = preferred"/>
        <column xsi:type="text" name="credentials_encrypted" nullable="true"
                comment="Encrypted JSON credentials blob"/>
        <column xsi:type="text" name="capabilities_cache_json" nullable="true"
                comment="Serialized CarrierCapabilitiesInterface snapshot"/>
        <column xsi:type="int" name="rate_limit_rpm" unsigned="true" nullable="false" default="60"
                comment="Rate limit in requests per minute"/>
        <column xsi:type="smallint" name="timeout_seconds" unsigned="true" nullable="false" default="10"
                comment="HTTP timeout (non-checkout calls)"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP"
                on_update="true" comment="Last update timestamp"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="carrier_code"/>
        </constraint>

        <index referenceId="SHUBO_SHIPPING_CARRIER_CONFIG_IS_ENABLED_PRIORITY" indexType="btree">
            <column name="is_enabled"/>
            <column name="priority"/>
        </index>
    </table>

    <!-- ================================================================
         6.4 shubo_shipping_geo_cache
         Geo data (cities, regions, PUDO) cached per carrier.
         ================================================================ -->
    <table name="shubo_shipping_geo_cache" resource="default" engine="innodb"
           comment="Geo Cache — per-carrier city/region/PUDO identifiers and metadata">
        <column xsi:type="int" name="geo_id" unsigned="true" nullable="false"
                identity="true" comment="Geo cache ID"/>
        <column xsi:type="varchar" name="carrier_code" nullable="false" length="40"
                comment="Owning carrier code"/>
        <column xsi:type="varchar" name="geo_type" nullable="false" length="20"
                comment="Geo type enum: city | region | pudo | district"/>
        <column xsi:type="varchar" name="external_id" nullable="false" length="64"
                comment="Carrier's own identifier"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255"
                comment="Human-readable name"/>
        <column xsi:type="varchar" name="name_en" nullable="true" length="255"
                comment="English name"/>
        <column xsi:type="int" name="parent_id" unsigned="true" nullable="true"
                comment="Self-FK for hierarchy (PUDO belongs to city)"/>
        <column xsi:type="decimal" name="latitude" scale="7" precision="10" nullable="true"
                comment="Latitude for distance-based PUDO selection"/>
        <column xsi:type="decimal" name="longitude" scale="7" precision="10" nullable="true"
                comment="Longitude"/>
        <column xsi:type="text" name="metadata_json" nullable="true"
                comment="Opening hours, cash accepted flags, etc."/>
        <column xsi:type="timestamp" name="refreshed_at" nullable="false" default="CURRENT_TIMESTAMP"
                on_update="true" comment="Cache staleness check timestamp"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="geo_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="SHUBO_SHIPPING_GEO_CACHE_CARRIER_CODE_GEO_TYPE_EXTERNAL_ID">
            <column name="carrier_code"/>
            <column name="geo_type"/>
            <column name="external_id"/>
        </constraint>

        <index referenceId="SHUBO_SHIPPING_GEO_CACHE_CARRIER_CODE_GEO_TYPE_PARENT_ID" indexType="btree">
            <column name="carrier_code"/>
            <column name="geo_type"/>
            <column name="parent_id"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_GEO_CACHE_GEO_TYPE_NAME" indexType="btree">
            <column name="geo_type"/>
            <column name="name"/>
        </index>
    </table>

    <!-- ================================================================
         6.5 shubo_shipping_invoice_import
         One row per carrier invoice we have ingested.
         ================================================================ -->
    <table name="shubo_shipping_invoice_import" resource="default" engine="innodb"
           comment="Invoice Import — carrier invoice ingest record">
        <column xsi:type="int" name="import_id" unsigned="true" nullable="false"
                identity="true" comment="Import ID"/>
        <column xsi:type="varchar" name="carrier_code" nullable="false" length="40"
                comment="Carrier code"/>
        <column xsi:type="date" name="period_start" nullable="false"
                comment="Invoice coverage start (carrier's billing period)"/>
        <column xsi:type="date" name="period_end" nullable="false"
                comment="Invoice coverage end"/>
        <column xsi:type="varchar" name="source_file_hash" nullable="false" length="64"
                comment="SHA-256 of the input file"/>
        <column xsi:type="varchar" name="source_file_path" nullable="false" length="512"
                comment="Archived path in media storage"/>
        <column xsi:type="varchar" name="source_format" nullable="false" length="16"
                comment="Format enum: xlsx | csv | pdf | json"/>
        <column xsi:type="int" name="total_lines" unsigned="true" nullable="false" default="0"
                comment="Total parsed lines"/>
        <column xsi:type="int" name="matched_lines" unsigned="true" nullable="false" default="0"
                comment="Lines matched to shipments"/>
        <column xsi:type="int" name="unmatched_lines" unsigned="true" nullable="false" default="0"
                comment="Lines with no matching shipment"/>
        <column xsi:type="int" name="disputed_lines" unsigned="true" nullable="false" default="0"
                comment="Lines flagged as disputed"/>
        <column xsi:type="varchar" name="status" nullable="false" length="20" default="pending"
                comment="Status enum: pending | parsing | imported | reconciled | failed"/>
        <column xsi:type="timestamp" name="imported_at" nullable="true"
                comment="When parsing completed"/>
        <column xsi:type="timestamp" name="reconciled_at" nullable="true"
                comment="When reconciliation completed"/>
        <column xsi:type="int" name="imported_by_admin_id" unsigned="true" nullable="true"
                comment="Admin user who triggered import; NULL for cron-triggered"/>
        <column xsi:type="text" name="error_message" nullable="true"
                comment="Error message when status=failed"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="import_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="SHUBO_SHIPPING_INVOICE_IMPORT_CARRIER_CODE_SOURCE_FILE_HASH">
            <column name="carrier_code"/>
            <column name="source_file_hash"/>
        </constraint>

        <index referenceId="SHUBO_SHIPPING_INVOICE_IMPORT_CARRIER_CODE_STATUS_PERIOD_END" indexType="btree">
            <column name="carrier_code"/>
            <column name="status"/>
            <column name="period_end"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_INVOICE_IMPORT_STATUS" indexType="btree">
            <column name="status"/>
        </index>
    </table>

    <!-- ================================================================
         6.6 shubo_shipping_invoice_line
         One row per parsed invoice line.
         ================================================================ -->
    <table name="shubo_shipping_invoice_line" resource="default" engine="innodb"
           comment="Invoice Line — one row per parsed carrier invoice line">
        <column xsi:type="bigint" name="line_id" unsigned="true" nullable="false"
                identity="true" comment="Line ID"/>
        <column xsi:type="int" name="import_id" unsigned="true" nullable="false"
                comment="FK to shubo_shipping_invoice_import.import_id"/>
        <column xsi:type="varchar" name="carrier_tracking_id" nullable="true" length="128"
                comment="Carrier tracking ID used for matching to shipments"/>
        <column xsi:type="varchar" name="external_line_id" nullable="true" length="128"
                comment="Carrier's own line identifier"/>
        <column xsi:type="int" name="shipment_id" unsigned="true" nullable="true"
                comment="Matched shipment ID; set after matching"/>
        <column xsi:type="bigint" name="expected_cod_cents" unsigned="true" nullable="false" default="0"
                comment="Expected COD in tetri (from shipment)"/>
        <column xsi:type="bigint" name="reported_cod_cents" unsigned="true" nullable="false" default="0"
                comment="Reported COD in tetri (from invoice)"/>
        <!-- reported_fee_cents is signed (bigint not bigint unsigned) because carriers can issue credits. -->
        <column xsi:type="bigint" name="reported_fee_cents" nullable="false" default="0"
                comment="Reported carrier fee in tetri; signed (credits allowed)"/>
        <column xsi:type="bigint" name="reported_vat_cents" unsigned="true" nullable="false" default="0"
                comment="Reported VAT on carrier fee in tetri"/>
        <column xsi:type="varchar" name="match_status" nullable="false" length="20" default="pending"
                comment="Match status enum: pending | matched | orphan | disputed | resolved"/>
        <column xsi:type="text" name="dispute_reason" nullable="true"
                comment="Human-readable dispute reason"/>
        <column xsi:type="timestamp" name="matched_at" nullable="true"
                comment="When the line matched"/>
        <column xsi:type="text" name="raw_line_json" nullable="false"
                comment="Full parsed source row"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="line_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="SHUBO_SHIPPING_INVOICE_LINE_IMPORT_ID"
                    table="shubo_shipping_invoice_line" column="import_id"
                    referenceTable="shubo_shipping_invoice_import" referenceColumn="import_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="SHUBO_SHIPPING_INVOICE_LINE_SHIPMENT_ID"
                    table="shubo_shipping_invoice_line" column="shipment_id"
                    referenceTable="shubo_shipping_shipment" referenceColumn="shipment_id"
                    onDelete="SET NULL"/>

        <index referenceId="SHUBO_SHIPPING_INVOICE_LINE_IMPORT_ID" indexType="btree">
            <column name="import_id"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_INVOICE_LINE_SHIPMENT_ID" indexType="btree">
            <column name="shipment_id"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_INVOICE_LINE_CARRIER_TRACKING_ID" indexType="btree">
            <column name="carrier_tracking_id"/>
        </index>
        <index referenceId="SHUBO_SHIPPING_INVOICE_LINE_MATCH_STATUS" indexType="btree">
            <column name="match_status"/>
        </index>
    </table>

    <!-- ================================================================
         6.7 shubo_shipping_circuit_breaker
         Per-carrier circuit-breaker state (persisted so it survives Redis flushes).
         ================================================================ -->
    <table name="shubo_shipping_circuit_breaker" resource="default" engine="innodb"
           comment="Circuit Breaker — per-carrier resilience state">
        <column xsi:type="varchar" name="carrier_code" nullable="false" length="40"
                comment="Carrier code (PK)"/>
        <column xsi:type="varchar" name="state" nullable="false" length="10" default="closed"
                comment="State enum: closed | open | half_open"/>
        <column xsi:type="int" name="failure_count" unsigned="true" nullable="false" default="0"
                comment="Rolling failure count in current window"/>
        <column xsi:type="int" name="success_count_since_halfopen" unsigned="true" nullable="false"
                default="0" comment="Consecutive successes since entering half_open"/>
        <column xsi:type="timestamp" name="last_failure_at" nullable="true"
                comment="Last failure timestamp"/>
        <column xsi:type="timestamp" name="last_success_at" nullable="true"
                comment="Last success timestamp"/>
        <column xsi:type="timestamp" name="opened_at" nullable="true"
                comment="When state transitioned to open"/>
        <column xsi:type="timestamp" name="cooldown_until" nullable="true"
                comment="When half-open trial is allowed"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP"
                on_update="true" comment="Last update timestamp"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="carrier_code"/>
        </constraint>

        <index referenceId="SHUBO_SHIPPING_CIRCUIT_BREAKER_STATE" indexType="btree">
            <column name="state"/>
        </index>
    </table>

    <!-- ================================================================
         6.8 shubo_shipping_rate_limit
         Per-carrier token-bucket state (DB fallback path; Redis is primary).
         ================================================================ -->
    <table name="shubo_shipping_rate_limit" resource="default" engine="innodb"
           comment="Rate Limit — per-carrier token-bucket window state (DB fallback)">
        <column xsi:type="varchar" name="carrier_code" nullable="false" length="40"
                comment="Carrier code (PK)"/>
        <column xsi:type="timestamp" name="window_start" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Start of the current 60-second window (epoch-aligned)"/>
        <column xsi:type="int" name="tokens_used" unsigned="true" nullable="false" default="0"
                comment="Tokens consumed in the current window"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP"
                on_update="true" comment="Last update timestamp"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="carrier_code"/>
        </constraint>
    </table>

</schema>
