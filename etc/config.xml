    Default values for the resilience primitives. Admin can override per
    scope via system.xml (Phase 9). Inline defaults in the services mirror
    these values so tests that don't load config still behave correctly.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <shubo_shipping>
            <breaker>
                <failure_threshold>5</failure_threshold>
                <failure_window_seconds>120</failure_window_seconds>
                <cooldown_seconds>60</cooldown_seconds>
                <success_threshold>3</success_threshold>
            </breaker>
            <rate_limit>
                <default_rpm>60</default_rpm>
            </rate_limit>
            <poller>
                <max_shipments_per_run>500</max_shipments_per_run>
            </poller>
        </shubo_shipping>

        <!--
            Shubo Flat Rate carrier (Phase 6).

            Ships disabled by default so Core's composer install does not
            suddenly add a flat-rate option to live checkouts. Operators
            enable via Stores -> Configuration -> Sales -> Shipping Methods
            -> Shubo Flat Rate.

            Code is `shuboflat` (no underscore) — the observer at
            Shubo\ShippingCore\Observer\CreateShipmentOnMagentoShipment
            splits Magento's shipping_method on `_` to extract the carrier
            code; an underscore in the carrier code would break that split.
        -->
        <carriers>
            <shuboflat>
                <active>0</active>
                <title>Shubo Flat Rate</title>
                <name>Standard</name>
                <price>5.00</price>
                <sallowspecific>0</sallowspecific>
                <sort_order>10</sort_order>
                <model>Shubo\ShippingCore\Model\Carrier\MagentoShippingMethod</model>
                <specificerrmsg>This shipping method is not available.</specificerrmsg>
            </shuboflat>
        </carriers>
    </default>
</config>
