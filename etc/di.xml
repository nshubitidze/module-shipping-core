<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Api interface bindings (Phase 3 + Phase 4) -->
    <preference for="Shubo\ShippingCore\Api\CircuitBreakerInterface"
                type="Shubo\ShippingCore\Model\Resilience\CircuitBreaker"/>
    <preference for="Shubo\ShippingCore\Api\RateLimiterInterface"
                type="Shubo\ShippingCore\Model\Resilience\RateLimiter"/>
    <preference for="Shubo\ShippingCore\Api\Data\CircuitBreakerStateInterface"
                type="Shubo\ShippingCore\Model\Data\CircuitBreakerState"/>

    <!-- Phase 4: Carrier registry + shipment orchestrator + repository -->
    <preference for="Shubo\ShippingCore\Api\CarrierRegistryInterface"
                type="Shubo\ShippingCore\Model\Carrier\CarrierRegistry"/>
    <preference for="Shubo\ShippingCore\Api\ShipmentOrchestratorInterface"
                type="Shubo\ShippingCore\Model\Orchestrator\ShipmentOrchestrator"/>
    <preference for="Shubo\ShippingCore\Api\ShipmentRepositoryInterface"
                type="Shubo\ShippingCore\Model\Shipment\ShipmentRepository"/>
    <preference for="Shubo\ShippingCore\Api\Data\ShipmentInterface"
                type="Shubo\ShippingCore\Model\Data\Shipment"/>
    <preference for="Shubo\ShippingCore\Api\Data\Search\ShipmentSearchResultsInterface"
                type="Shubo\ShippingCore\Model\Data\ShipmentSearchResults"/>

    <!-- Phase 6: Rate quote service (carrier-agnostic aggregator) -->
    <preference for="Shubo\ShippingCore\Api\RateQuoteServiceInterface"
                type="Shubo\ShippingCore\Model\Carrier\RateQuoteService"/>

    <!--
        Phase 5a: Tracking poller.

        TODO(Phase 5b / Phase 4 gap): the concrete
        Shubo\ShippingCore\Api\ShipmentEventRepositoryInterface implementation
        and Shubo\ShippingCore\Model\Data\ShipmentEvent are not yet in this
        module. A follow-up task must land
        `Shubo\ShippingCore\Model\Shipment\ShipmentEventRepository` plus the
        concrete ShipmentEvent AbstractModel + resource before the cron can
        execute at runtime. See design doc §7.12. Unit tests cover the poller
        via interface mocks, which is why this phase is still shippable.
    -->
    <preference for="Shubo\ShippingCore\Api\TrackingPollerInterface"
                type="Shubo\ShippingCore\Model\Tracking\TrackingPoller"/>

    <!--
        Carrier registry composition — adapter modules register themselves
        by appending to the `gateways` / `capabilities` arrays from their
        own di.xml (see design doc section 7.3). Core ships the built-in
        flat-rate adapter (Phase 6) so a freshly-installed marketplace has
        at least one working carrier out of the box.

        External adapters (e.g. a future Shubo_TrackingsGe) register
        themselves by ADDING to these arrays from their own di.xml. They
        MUST NOT redeclare the same `shuboflat` key here.
    -->
    <type name="Shubo\ShippingCore\Model\Carrier\CarrierRegistry">
        <arguments>
            <argument name="gateways" xsi:type="array">
                <item name="shuboflat" xsi:type="object">Shubo\ShippingCore\Model\Carrier\FlatRateGateway</item>
            </argument>
            <argument name="capabilities" xsi:type="array">
                <item name="shuboflat" xsi:type="object">Shubo\ShippingCore\Model\Carrier\FlatRateCapabilities</item>
            </argument>
        </arguments>
    </type>

    <!-- Dedicated log channel: var/log/shubo_shipping.log. Mirrors the
         Shubo_Payout pattern (app/code/Shubo/Payout/etc/di.xml:42-55). -->
    <virtualType name="ShuboShippingCoreLogHandler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/shubo_shipping.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="ShuboShippingCoreLogger"
                 type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ShuboShippingCoreLogHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Inject the dedicated logger into StructuredLogger. -->
    <type name="Shubo\ShippingCore\Model\Logging\StructuredLogger">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboShippingCoreLogger</argument>
        </arguments>
    </type>

</config>
