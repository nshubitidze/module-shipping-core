<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Api interface bindings (Phase 3 + Phase 4) -->
    <preference for="Shubo\ShippingCore\Api\CircuitBreakerInterface"
                type="Shubo\ShippingCore\Model\Resilience\CircuitBreaker"/>
    <preference for="Shubo\ShippingCore\Api\RateLimiterInterface"
                type="Shubo\ShippingCore\Model\Resilience\RateLimiter"/>
    <preference for="Shubo\ShippingCore\Api\Data\CircuitBreakerStateInterface"
                type="Shubo\ShippingCore\Model\Data\CircuitBreakerState"/>

    <!-- Phase 4: Carrier registry + shipment orchestrator + repository -->
    <preference for="Shubo\ShippingCore\Api\CarrierRegistryInterface"
                type="Shubo\ShippingCore\Model\Carrier\CarrierRegistry"/>
    <preference for="Shubo\ShippingCore\Api\ShipmentOrchestratorInterface"
                type="Shubo\ShippingCore\Model\Orchestrator\ShipmentOrchestrator"/>
    <preference for="Shubo\ShippingCore\Api\ShipmentRepositoryInterface"
                type="Shubo\ShippingCore\Model\Shipment\ShipmentRepository"/>
    <preference for="Shubo\ShippingCore\Api\Data\ShipmentInterface"
                type="Shubo\ShippingCore\Model\Data\Shipment"/>
    <preference for="Shubo\ShippingCore\Api\Data\Search\ShipmentSearchResultsInterface"
                type="Shubo\ShippingCore\Model\Data\ShipmentSearchResults"/>

    <!-- Phase 4 completion: shipment-event persistence layer -->
    <preference for="Shubo\ShippingCore\Api\Data\ShipmentEventInterface"
                type="Shubo\ShippingCore\Model\Data\ShipmentEvent"/>
    <preference for="Shubo\ShippingCore\Api\ShipmentEventRepositoryInterface"
                type="Shubo\ShippingCore\Model\Shipment\ShipmentEventRepository"/>

    <!--
        Phase 6: Rate quote service (carrier-agnostic aggregator).

        Wrapped in a 10-minute read-through cache (design doc §12.4) keyed by
        origin + destination + parcel + merchant. Cache misses delegate to
        the raw aggregator; cache read/write failures fall through silently
        so a Redis outage can never block checkout.
    -->
    <virtualType name="ShuboShippingRawRateQuoteService"
                 type="Shubo\ShippingCore\Model\Carrier\RateQuoteService"/>
    <preference for="Shubo\ShippingCore\Api\RateQuoteServiceInterface"
                type="Shubo\ShippingCore\Model\Carrier\CachedRateQuoteService"/>
    <type name="Shubo\ShippingCore\Model\Carrier\CachedRateQuoteService">
        <arguments>
            <argument name="inner" xsi:type="object">ShuboShippingRawRateQuoteService</argument>
        </arguments>
    </type>

    <!-- Phase 5a: Tracking poller. -->
    <preference for="Shubo\ShippingCore\Api\TrackingPollerInterface"
                type="Shubo\ShippingCore\Model\Tracking\TrackingPoller"/>

    <!-- Phase 10: Dead-letter repository (durable DLQ sink). -->
    <preference for="Shubo\ShippingCore\Api\Data\DeadLetterEntryInterface"
                type="Shubo\ShippingCore\Model\Data\DeadLetterEntry"/>
    <preference for="Shubo\ShippingCore\Api\DeadLetterRepositoryInterface"
                type="Shubo\ShippingCore\Model\Resilience\DeadLetterRepository"/>

    <!--
        Carrier registry composition — adapter modules register themselves
        by appending to the `gateways` / `capabilities` arrays from their
        own di.xml (see design doc section 7.3). Core ships the built-in
        flat-rate adapter (Phase 6) so a freshly-installed marketplace has
        at least one working carrier out of the box.

        External adapters (e.g. a future Shubo_TrackingsGe) register
        themselves by ADDING to these arrays from their own di.xml. They
        MUST NOT redeclare the same `shuboflat` key here.
    -->
    <type name="Shubo\ShippingCore\Model\Carrier\CarrierRegistry">
        <arguments>
            <argument name="gateways" xsi:type="array">
                <item name="shuboflat" xsi:type="object">Shubo\ShippingCore\Model\Carrier\FlatRateGateway</item>
            </argument>
            <argument name="capabilities" xsi:type="array">
                <item name="shuboflat" xsi:type="object">Shubo\ShippingCore\Model\Carrier\FlatRateCapabilities</item>
            </argument>
        </arguments>
    </type>

    <!--
        Phase 10: CLI commands.

        MUST bind on `CommandListInterface` not the concrete `CommandList`.
        Binding on the concrete class causes Magento's ObjectManager to
        eagerly resolve the full command dependency graph during
        `setup:install`, which in turn resolves TransportBuilder /
        StoreManager / the website patch — and crashes on a cold install.
        See KNOWN_ISSUES.md BUG-SETUP-1 Symptom 2 (2026-04-20).
    -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="shubo_shipping_poll"
                      xsi:type="object">Shubo\ShippingCore\Console\Command\PollCommand</item>
                <item name="shubo_shipping_dlq_list"
                      xsi:type="object">Shubo\ShippingCore\Console\Command\DlqListCommand</item>
                <item name="shubo_shipping_dlq_reprocess"
                      xsi:type="object">Shubo\ShippingCore\Console\Command\DlqReprocessCommand</item>
                <item name="shubo_shipping_schema_drift"
                      xsi:type="object">Shubo\ShippingCore\Console\Command\SchemaDriftCommand</item>
            </argument>
        </arguments>
    </type>

    <!-- Dedicated log channel: var/log/shubo_shipping.log. Mirrors the
         Shubo_Payout pattern (app/code/Shubo/Payout/etc/di.xml:42-55). -->
    <virtualType name="ShuboShippingCoreLogHandler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <!--
                Relative path is resolved by Monolog's Base handler against
                Magento's BP . '/var/log/' so php-fpm writes under the project
                root (see \Magento\Framework\Logger\Handler\Base::__construct).
                An absolute '/var/log/...' breaks on Hetzner where the system
                /var/log is not writable by www-data and every StructuredLogger
                call is silently dropped. Fix for BUG-SHIPPING-LOG-1.
            -->
            <argument name="fileName" xsi:type="string">var/log/shubo_shipping.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="ShuboShippingCoreLogger"
                 type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ShuboShippingCoreLogHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Inject the dedicated logger into StructuredLogger. -->
    <type name="Shubo\ShippingCore\Model\Logging\StructuredLogger">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboShippingCoreLogger</argument>
        </arguments>
    </type>

    <!--
        Phase 5b: Webhook dispatcher.

        Adapter modules that opt into webhooks register their handler by
        appending to the `handlers` array from their own di.xml (see design
        doc §8). Core ships an empty map here so the dispatcher boots with
        zero carriers and an unknown-carrier lookup short-circuits to 404
        instead of blowing up.
    -->
    <preference for="Shubo\ShippingCore\Api\WebhookReceiverInterface"
                type="Shubo\ShippingCore\Model\Webhook\WebhookReceiver"/>

    <type name="Shubo\ShippingCore\Model\Webhook\WebhookDispatcher">
        <arguments>
            <argument name="handlers" xsi:type="array"/>
        </arguments>
    </type>

</config>
